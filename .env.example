DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vantageciso"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-me"
AUTH_SECRET="replace-me"

APP_BASE_URL="http://localhost:3000"
DEMO_MODE="false"
DEMO_USER_EMAIL="admin@vantageciso.local"
# Optional: if DEMO_USER_EMAIL belongs to multiple tenants, pin one by slug.
DEMO_TENANT_SLUG=""

# Infrastructure decisions (defaults)
DEFAULT_STORAGE_PROVIDER="LOCAL"
DEFAULT_VECTOR_PROVIDER="HASHED"
DEFAULT_EMAIL_PROVIDER="RESEND"

# Email (Auth.js magic links)
AUTH_EMAIL_FROM="no-reply@yourdomain.com"
RESEND_API_KEY=""

# AI + vector embedding fallback
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# S3-compatible object storage (optional)
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_PARTNER=""
