  status           RoadmapStatus     @default(DRAFT)
  reviewerNotes    String?
  createdBy        String
  reviewedBy       String?
  approvedBy       String?
  reviewedAt       DateTime?
  approvedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  snapshot         PulseSnapshot     @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  items            RoadmapItem[]
  boardBriefs      BoardBrief[]
  quarterlyReviews QuarterlyReview[]

  @@index([tenantId, status, updatedAt])
}

model RoadmapItem {
  id               String            @id @default(cuid())
  tenantId         String
  roadmapId        String
  title            String
  horizon          RoadmapHorizon
  ownerUserId      String?
  dueAt            DateTime?
  status           RoadmapItemStatus @default(PLANNED)
  rationale        String
  expectedImpact   String
  linkedRiskIds    String[]          @default([])
  linkedFindingIds String[]          @default([])
  linkedTaskIds    String[]          @default([])
  linkedControlIds String[]          @default([])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roadmap          PulseRoadmap      @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@index([tenantId, roadmapId, horizon])
  @@index([tenantId, status, dueAt])
}

model BoardBrief {
  id                        String            @id @default(cuid())
  tenantId                  String
  snapshotId                String
  roadmapId                 String
  title                     String
  reportingPeriod           String
  status                    BoardBriefStatus  @default(DRAFT)
  overallPostureSummary     String
  topRiskIds                String[]          @default([])
  notableImprovements       String[]          @default([])
  overdueActions            String[]          @default([])
  leadershipDecisionsNeeded String[]          @default([])
  roadmap30Days             String[]          @default([])
  roadmap60Days             String[]          @default([])
  roadmap90Days             String[]          @default([])
  reviewerNotes             String?
  createdBy                 String
  reviewedBy                String?
  approvedBy                String?
  reviewedAt                DateTime?
  approvedAt                DateTime?
  lastExportedAt            DateTime?
  exportCount               Int               @default(0)
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  tenant                    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  snapshot                  PulseSnapshot     @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  roadmap                   PulseRoadmap      @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  quarterlyReviews          QuarterlyReview[]

  @@index([tenantId, status, updatedAt])
  @@index([tenantId, snapshotId, updatedAt])
}

model QuarterlyReview {
  id              String                @id @default(cuid())
  tenantId        String
  snapshotId      String
  roadmapId       String
  boardBriefId    String
  reviewPeriod    String
  reviewDate      DateTime
  attendeeNames   String[]              @default([])
  notes           String?
  decisionsMade   String[]              @default([])
  followUpActions String[]              @default([])
  topRiskIds      String[]              @default([])
  status          QuarterlyReviewStatus @default(DRAFT)
  createdBy       String
  finalizedBy     String?
  finalizedAt     DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  snapshot        PulseSnapshot         @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  roadmap         PulseRoadmap          @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  boardBrief      BoardBrief            @relation(fields: [boardBriefId], references: [id], onDelete: Cascade)

  @@unique([tenantId, reviewPeriod])
  @@index([tenantId, status, reviewDate])
}

model Incident {
  id                      String             @id @default(cuid())
  tenantId                String
  title                   String
  description             String
  incidentType            IncidentType
  severity                IncidentSeverity
  status                  IncidentStatus     @default(NEW)
  detectionSource         String?
  reportedBy              String?
  incidentOwnerUserId     String?
  communicationsOwnerUserId String?
  affectedSystems         String[]           @default([])
  affectedServices        String[]           @default([])
  affectedVendorNames     String[]           @default([])
  aiUseCaseId             String?
  aiVendorReviewId        String?
  questionnaireUploadId   String?
  trustInboxItemId        String?
  startedAt               DateTime           @default(now())
  declaredAt              DateTime?
  containedAt             DateTime?
  resolvedAt              DateTime?
  nextUpdateDueAt         DateTime?
  executiveSummary        String?
  internalNotes           String?
  linkedFindingIds        String[]           @default([])
  linkedRiskIds           String[]           @default([])
  linkedBoardBriefIds     String[]           @default([])
  linkedQuarterlyReviewIds String[]          @default([])
  createdBy               String
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  tenant                  Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aiUseCase               AIUseCase?         @relation(fields: [aiUseCaseId], references: [id], onDelete: SetNull)
  aiVendorReview          AIVendorReview?    @relation(fields: [aiVendorReviewId], references: [id], onDelete: SetNull)
  questionnaireUpload     QuestionnaireUpload? @relation(fields: [questionnaireUploadId], references: [id], onDelete: SetNull)
  trustInboxItem          TrustInboxItem?    @relation(fields: [trustInboxItemId], references: [id], onDelete: SetNull)
  tasks                   Task[]
  findings                Finding[]
  timelineEvents          IncidentTimelineEvent[]
  runbookPacks            IncidentRunbookPack[]
  afterActionReports      AfterActionReport[]

  @@index([tenantId, status, severity, updatedAt])
  @@index([tenantId, incidentOwnerUserId, nextUpdateDueAt])
  @@index([tenantId, incidentType, createdAt])
  @@index([tenantId, aiUseCaseId])
  @@index([tenantId, aiVendorReviewId])
}

model IncidentRunbookPack {
  id          String                    @id @default(cuid())
  tenantId    String
  incidentId  String
  runbookId   String
  title       String
  summary     String?
  status      IncidentRunbookPackStatus @default(ACTIVE)
  createdBy   String
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  tenant      Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  incident    Incident                  @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@index([tenantId, incidentId, updatedAt])
  @@index([tenantId, status, updatedAt])
}

model IncidentTimelineEvent {
  id          String                    @id @default(cuid())
  tenantId    String
  incidentId  String
  eventType   IncidentTimelineEventType
  title       String
  detail      String?
  isShareable Boolean                   @default(false)
  createdBy   String
  createdAt   DateTime                  @default(now())
  tenant      Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  incident    Incident                  @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([tenantId, incidentId, createdAt])
  @@index([tenantId, eventType, createdAt])
}

model AfterActionReport {
  id               String                  @id @default(cuid())
  tenantId         String
  incidentId       String                  @unique
  title            String
  status           AfterActionReportStatus @default(DRAFT)
  summary          String
  affectedScope    String
  timelineSummary  String[]                @default([])
  actionsTaken     String[]                @default([])
  currentStatus    String
  lessonsLearned   String[]                @default([])
  followUpActions  String[]                @default([])
  decisionsNeeded  String[]                @default([])
  linkedFindingIds String[]                @default([])
  linkedRiskIds    String[]                @default([])
  linkedTaskIds    String[]                @default([])
  reviewerNotes    String?
  createdBy        String
  reviewedBy       String?
  approvedBy       String?
  reviewedAt       DateTime?
  approvedAt       DateTime?
  lastExportedAt   DateTime?
  exportCount      Int                     @default(0)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  tenant           Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  incident         Incident                @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, updatedAt])
  @@index([tenantId, incidentId, updatedAt])
}

model TabletopExercise {
  id               String                @id @default(cuid())
  tenantId         String
  title            String
  scenarioType     IncidentType
  status           TabletopExerciseStatus @default(DRAFT)
  exerciseDate     DateTime
  participantNames String[]              @default([])
  participantRoles String[]              @default([])
  scenarioSummary  String
  exerciseObjectives String[]            @default([])
  expectedDecisions String[]             @default([])
  exerciseNotes    String?
  decisionsMade    String[]              @default([])
  gapsIdentified   String[]              @default([])
  followUpActions  String[]              @default([])
  linkedFindingIds String[]              @default([])
  linkedRiskIds    String[]              @default([])
  linkedTaskIds    String[]              @default([])
  reviewerNotes    String?
  createdBy        String
  completedBy      String?
  completedAt      DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tasks            Task[]
  findings         Finding[]

  @@index([tenantId, status, exerciseDate])
  @@index([tenantId, scenarioType, updatedAt])
}

model TrustDoc {
  id         String   @id @default(cuid())
  tenantId   String
  category   String
  evidenceId String
  tagsJson   Json?
  createdBy  String
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  evidence   Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  @@unique([tenantId, evidenceId])
  @@index([tenantId, category])
}

model TrustInboxAttachment {
  id          String         @id @default(cuid())
  tenantId    String
  inboxItemId String
  evidenceId  String
  createdBy   String
  createdAt   DateTime       @default(now())
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inboxItem   TrustInboxItem @relation(fields: [inboxItemId], references: [id], onDelete: Cascade)
  evidence    Evidence       @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  @@unique([inboxItemId, evidenceId])
  @@index([tenantId, inboxItemId])
}

model Report {
  id           String         @id @default(cuid())
  tenantId     String
  assessmentId String
  title        String
  summary      String
  markdown     String
  jsonPayload  Json
  generatedBy  String
  createdAt    DateTime       @default(now())
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessment   Assessment     @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  exports      ReportExport[]

  @@index([tenantId, assessmentId])
}

model ReportExport {
  id         String       @id @default(cuid())
  tenantId   String
  reportId   String
  format     ReportFormat
  storageKey String?
  fileName   String
  createdBy  String
  createdAt  DateTime     @default(now())
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  report     Report       @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([tenantId, reportId])
}

model TenantBranding {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  companyName  String
  logoUrl      String?
  primaryColor String   @default("#0f172a")
  accentColor  String   @default("#2563eb")
  footerNote   String   @default("Not legal advice.")
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  actorUserId String
  entityType  String
  entityId    String
  action      String
  metadata    Json
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

model StripeCustomer {
  id               String   @id @default(cuid())
  tenantId         String
  stripeCustomerId String   @unique
  createdAt        DateTime @default(now())
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId])
}

model Subscription {
  id                   String    @id @default(cuid())
  tenantId             String
  plan                 PlanTier  @default(STARTER)
  stripeSubscriptionId String?   @unique
  status               String
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  endedAt              DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

model BillingWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  tenantId      String?
  type          String
  payload       Json
  processedAt   DateTime @default(now())
  tenant        Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
