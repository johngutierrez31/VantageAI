generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum TemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AssessmentStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
}

enum PlanTier {
  FREE
  STARTER
  PRO
  BUSINESS
  ENTERPRISE
}

enum WorkspaceMode {
  DEMO
  TRIAL
  PAID
}

enum TrialStatus {
  NOT_STARTED
  ACTIVE
  EXPIRED
  CONVERTED
}

enum StorageProvider {
  LOCAL
  S3
}

enum VectorProvider {
  HASHED
  OPENAI
}

enum EmailProvider {
  RESEND
}

enum IngestionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum QuestionnaireImportStatus {
  PENDING
  APPLIED
  FAILED
}

enum QuestionnaireSourceType {
  CSV
  JSON
}

enum ReportFormat {
  HTML
  MARKDOWN
  JSON
  PDF
}

enum TemplateQuestionType {
  LIKERT
  TEXT
  MULTI
}

enum QuestionnaireOriginalFormat {
  CSV
  XLSX
  DOCX
  JSON
}

enum QuestionnaireMappingStatus {
  MAPPED
  UNMAPPED
}

enum QuestionnaireUploadStatus {
  UPLOADED
  MAPPED
  DRAFTED
  NEEDS_REVIEW
  APPROVED
  EXPORTED
}

enum DraftAnswerStatus {
  DRAFT
  NEEDS_REVIEW
  APPROVED
  REJECTED
}

enum ApprovedAnswerScope {
  REUSABLE
  TENANT_SPECIFIC
}

enum ApprovedAnswerStatus {
  ACTIVE
  ARCHIVED
}

enum TrustInboxStatus {
  NEW
  IN_REVIEW
  DRAFT_READY
  DELIVERED
}

enum TrustPacketStatus {
  DRAFT
  READY_FOR_REVIEW
  READY_TO_SHARE
  SHARED
}

enum TrustPacketShareMode {
  INTERNAL_REVIEW
  EXTERNAL_SHARE
}

enum TrustRoomStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum TrustRoomAccessMode {
  INTERNAL_REVIEW
  PROTECTED_LINK
  REQUEST_ACCESS
}

enum TrustRoomAccessRequestStatus {
  PENDING
  APPROVED
  DENIED
  FULFILLED
}

enum TrustRoomEngagementEventType {
  ROOM_VIEWED
  SECTION_VIEWED
  PACKET_DOWNLOADED
  REQUEST_SUBMITTED
  ACCESS_GRANTED
}

enum ConnectorProvider {
  SLACK
  JIRA
  CONFLUENCE
  GOOGLE_DRIVE
  OUTBOUND_WEBHOOK
}

enum ConnectorMode {
  SIMULATED
  LIVE
}

enum ConnectorStatus {
  ACTIVE
  NEEDS_ATTENTION
  DISABLED
}

enum ConnectorActivityStatus {
  PENDING
  SUCCEEDED
  FAILED
  SKIPPED
}

enum AdoptionImportTarget {
  FINDINGS
  RISKS
  APPROVED_ANSWERS
  INCIDENTS
}

enum AdoptionImportSource {
  MANUAL
  CSV
  CONNECTOR_EXPORT
}

enum AdoptionImportStatus {
  SUCCEEDED
  PARTIAL
  FAILED
}

enum EvidenceMapStatus {
  DRAFT
  NEEDS_REVIEW
  APPROVED
  ARCHIVED
}

enum EvidenceMapSupportStrength {
  STRONG
  MODERATE
  WEAK
  MISSING
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ExceptionStatus {
  OPEN
  ACCEPTED
  CLOSED
}

enum EvidenceRequestStatus {
  REQUESTED
  RECEIVED
  COMPLETE
}

enum FindingStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  ARCHIVED
}

enum FindingSourceType {
  TRUSTOPS_EVIDENCE_GAP
  TRUSTOPS_REJECTION
  TRUSTOPS_EVIDENCE_MAP
  AI_GOVERNANCE_HIGH_RISK
  AI_GOVERNANCE_REJECTION
  AI_VENDOR_REVIEW
  RESPONSE_OPS_INCIDENT
  RESPONSE_OPS_AFTER_ACTION
  RESPONSE_OPS_TABLETOP
  ADOPTION_IMPORT
}

enum PulseSnapshotPeriodType {
  MONTHLY
  QUARTERLY
}

enum PulseSnapshotStatus {
  DRAFT
  NEEDS_REVIEW
  APPROVED
  PUBLISHED
}

enum PulseSourceModule {
  TRUSTOPS
  ASSESSMENTS
  FINDINGS
  TASKS
  PULSE
  AI_GOVERNANCE
  RESPONSE_OPS
  MANUAL
}

enum RiskRegisterSourceType {
  MANUAL
  FINDING
  TRUSTOPS_EVIDENCE_GAP
  TRUSTOPS_REJECTION
  TRUSTOPS_EVIDENCE_MAP
  ASSESSMENT_GAP
  TASK
  PULSE_CATEGORY
  AI_USE_CASE
  AI_VENDOR_REVIEW
  INCIDENT
  TABLETOP
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskRegisterStatus {
  OPEN
  IN_REVIEW
  MITIGATING
  ACCEPTED
  CLOSED
}

enum RoadmapStatus {
  DRAFT
  NEEDS_REVIEW
  APPROVED
  ARCHIVED
}

enum RoadmapHorizon {
  DAYS_30
  DAYS_60
  DAYS_90
}

enum RoadmapItemStatus {
  PLANNED
  IN_PROGRESS
  BLOCKED
  DONE
}

enum BoardBriefStatus {
  DRAFT
  NEEDS_REVIEW
  APPROVED
}

enum QuarterlyReviewStatus {
  DRAFT
  FINALIZED
}

enum IncidentStatus {
  NEW
  TRIAGE
  ACTIVE
  CONTAINED
  RECOVERING
  RESOLVED
  POST_INCIDENT_REVIEW
  ARCHIVED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentType {
  IDENTITY_COMPROMISE
  RANSOMWARE
  PHISHING
  THIRD_PARTY_BREACH
  CLOUD_EXPOSURE
  LOST_DEVICE
  AI_MISUSE
  OTHER
}

enum ResponseOpsPhase {
  TRIAGE
  EVIDENCE_COLLECTION
  CONTAINMENT
  ERADICATION
  RECOVERY
  COMMUNICATIONS
  POST_INCIDENT_REVIEW
}

enum IncidentRunbookPackStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum IncidentTimelineEventType {
  CREATED
  TRIAGE_STARTED
  STATUS_CHANGED
  RUNBOOK_LAUNCHED
  COMMUNICATION_SENT
  CONTAINMENT_COMPLETED
  DECISION_LOG
  NOTE
  AFTER_ACTION_GENERATED
  TABLETOP_LINKED
}

enum AfterActionReportStatus {
  DRAFT
  NEEDS_REVIEW
  APPROVED
}

enum TabletopExerciseStatus {
  DRAFT
  COMPLETED
  ARCHIVED
}

enum AIGovernanceStatus {
  DRAFT
  NEEDS_REVIEW
  APPROVED
  APPROVED_WITH_CONDITIONS
  REJECTED
  ARCHIVED
}

enum AIUseCaseType {
  INTERNAL_PRODUCTIVITY
  CUSTOMER_FACING
  SECURITY_WORKFLOW
  ENGINEERING_WORKFLOW
  CONTENT_WORKFLOW
  ANALYTICS_WORKFLOW
  OTHER
}

enum AIWorkflowType {
  ASSISTANT
  CHATBOT
  AUTOMATION
  AGENT
  RAG
  ANALYTICS
  CONTENT_GENERATION
  OTHER
}

enum AIDeploymentContext {
  SAAS
  INTERNAL
  HYBRID
  API
  LOCAL_MODEL
  OTHER
}

enum AIRiskTier {
  LOW
  MODERATE
  HIGH
  CRITICAL
}

enum AIYesNoUnknown {
  YES
  NO
  UNKNOWN
}

enum AIRetentionStatus {
  KNOWN
  UNKNOWN
  NO_RETENTION
}

enum AIDpaStatus {
  NOT_STARTED
  REQUESTED
  RECEIVED
  SIGNED
  NOT_REQUIRED
}

enum AIDataClass {
  PUBLIC
  INTERNAL
  CONFIDENTIAL
  CUSTOMER_DATA
  CUSTOMER_CONTENT
  CUSTOMER_METADATA
  PII
  PHI
  PCI
  FINANCIAL
  SOURCE_CODE
  SECRETS
  SECURITY_LOGS
  HR
}

enum AIPolicyRequirement {
  HUMAN_REVIEW_REQUIRED
  APPROVED_VENDOR_ONLY
  NO_CUSTOMER_SECRETS
  NO_REGULATED_DATA
  NO_INTERNET_ACCESS
  NO_EXTERNAL_TOOL_INVOCATION
  LOGGING_REQUIRED
  RETENTION_MUST_BE_KNOWN
}

model Tenant {
  id                    String                   @id @default(cuid())
  name                  String
  slug                  String                   @unique
  workspaceMode         WorkspaceMode            @default(PAID)
  trialStatus           TrialStatus              @default(NOT_STARTED)
  trialStartedAt        DateTime?
  trialEndsAt           DateTime?
  activeStorageProvider StorageProvider          @default(LOCAL)
  activeVectorProvider  VectorProvider           @default(HASHED)
  activeEmailProvider   EmailProvider            @default(RESEND)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  memberships           Membership[]
  templates             Template[]
  templateVersions      TemplateVersion[]
  templateSections      TemplateSection[]
  controls              Control[]
  questions             Question[]
  assessments           Assessment[]
  responses             Response[]
  evidenceItems         Evidence[]
  evidenceChunks        EvidenceChunk[]
  evidenceLinks         EvidenceLink[]
  aiSuggestions         AISuggestion[]
  exceptions            Exception[]
  questionnaireImports  QuestionnaireImport[]
  questionnaireRows     QuestionnaireImportRow[]
  reports               Report[]
  reportExports         ReportExport[]
  tasks                 Task[]
  evidenceRequests      EvidenceRequest[]
  questionnaireUploads  QuestionnaireUpload[]
  questionnaireItems    QuestionnaireItem[]
  questionnaireMappings QuestionnaireMapping[]
  draftAnswers          DraftAnswer[]
  approvedAnswers       ApprovedAnswer[]
  evidenceMaps          EvidenceMap[]
  evidenceMapItems      EvidenceMapItem[]
  trustInboxItems       TrustInboxItem[]
  trustDocs             TrustDoc[]
  trustInboxAttachments TrustInboxAttachment[]
  trustPackets          TrustPacket[]
  trustRooms            TrustRoom[]
  trustRoomAccessRequests TrustRoomAccessRequest[]
  trustRoomEngagementEvents TrustRoomEngagementEvent[]
  connectorConfigs      ConnectorConfig[]
  connectorActivities   ConnectorActivity[]
  connectorObjectLinks  ConnectorObjectLink[]
  adoptionImports       AdoptionImport[]
  findings              Finding[]
  pulseSnapshots        PulseSnapshot[]
  pulseCategoryScores   PulseCategoryScore[]
  riskRegisterItems     RiskRegisterItem[]
  pulseRoadmaps         PulseRoadmap[]
  roadmapItems          RoadmapItem[]
  boardBriefs           BoardBrief[]
  quarterlyReviews      QuarterlyReview[]
  aiUseCases            AIUseCase[]
  aiVendorReviews       AIVendorReview[]
  incidents             Incident[]
  incidentRunbookPacks  IncidentRunbookPack[]
  incidentTimelineEvents IncidentTimelineEvent[]
  afterActionReports    AfterActionReport[]
  tabletopExercises     TabletopExercise[]
  branding              TenantBranding?
  auditLogs             AuditLog[]
  stripeCustomers       StripeCustomer[]
  subscriptions         Subscription[]
  billingWebhookEvents  BillingWebhookEvent[]
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  memberships   Membership[]
  accounts      Account[]
  sessions      Session[]
  credential    UserCredential?
}

model UserCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Membership {
  id        String           @id @default(cuid())
  tenantId  String
  userId    String
  role      TenantRole
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId, status])
}

model Template {
  id               String            @id @default(cuid())
  tenantId         String
  name             String
  description      String?
  status           TemplateStatus    @default(DRAFT)
  currentVersionId String?
  createdBy        String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  versions         TemplateVersion[]
  assessments      Assessment[]

  @@unique([tenantId, name])
}

model TemplateVersion {
  id          String            @id @default(cuid())
  tenantId    String
  templateId  String
  version     Int
  title       String
  notes       String?
  isPublished Boolean           @default(false)
  createdAt   DateTime          @default(now())
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template    Template          @relation(fields: [templateId], references: [id], onDelete: Cascade)
  controls    Control[]
  sections    TemplateSection[]

  @@unique([templateId, version])
  @@index([tenantId, templateId])
}

model Control {
  id                String          @id @default(cuid())
  tenantId          String
  templateVersionId String
  domain            String
  code              String
  title             String
  description       String?
  weight            Float           @default(1)
  createdAt         DateTime        @default(now())
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  templateVersion   TemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Cascade)
  questions         Question[]

  @@unique([templateVersionId, code])
  @@index([tenantId, templateVersionId])
}

model Question {
  id                    String                   @id @default(cuid())
  tenantId              String
  controlId             String
  sectionId             String?
  prompt                String
  guidance              String?
  answerType            TemplateQuestionType     @default(TEXT)
  rubric                String
  scoringRubricJson     Json?
  order                 Int                      @default(0)
  weight                Float                    @default(1)
  createdAt             DateTime                 @default(now())
  tenant                Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  control               Control                  @relation(fields: [controlId], references: [id], onDelete: Cascade)
  section               TemplateSection?         @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  responses             Response[]
  evidenceLinks         EvidenceLink[]
  importRows            QuestionnaireImportRow[]
  questionnaireMappings QuestionnaireMapping[]

  @@index([controlId, order])
  @@index([sectionId, order])
}

model TemplateSection {
  id                String          @id @default(cuid())
  tenantId          String
  templateVersionId String
  title             String
  order             Int             @default(0)
  createdAt         DateTime        @default(now())
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  templateVersion   TemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Cascade)
  questions         Question[]

  @@index([tenantId, templateVersionId, order])
}

model Assessment {
  id                   String                @id @default(cuid())
  tenantId             String
  templateId           String
  templateVersionId    String
  name                 String
  customerName         String
  status               AssessmentStatus      @default(DRAFT)
  createdBy            String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template             Template              @relation(fields: [templateId], references: [id], onDelete: Restrict)
  responses            Response[]
  questionnaireImports QuestionnaireImport[]
  reports              Report[]
  tasks                Task[]
  exceptions           Exception[]
  evidenceRequests     EvidenceRequest[]
}

model Response {
  id            String                   @id @default(cuid())
  tenantId      String
  assessmentId  String
  questionId    String
  answer        String?
  score         Float?
  confidence    Float?
  rationale     String?
  updatedBy     String
  updatedAt     DateTime                 @updatedAt
  createdAt     DateTime                 @default(now())
  tenant        Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessment    Assessment               @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question      Question                 @relation(fields: [questionId], references: [id], onDelete: Cascade)
  evidenceLinks EvidenceLink[]
  importRows    QuestionnaireImportRow[]

  @@unique([assessmentId, questionId])
  @@index([tenantId, assessmentId])
}

model Evidence {
  id                    String                 @id @default(cuid())
  tenantId              String
  name                  String
  storageKey            String
  mimeType              String
  byteSize              Int?
  sha256                String?
  sourceUri             String?
  tags                  String[]
  extractedText         String?
  ingestionStatus       IngestionStatus        @default(PENDING)
  ingestionError        String?
  extractedAt           DateTime?
  createdBy             String
  createdAt             DateTime               @default(now())
  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  links                 EvidenceLink[]
  chunks                EvidenceChunk[]
  trustDocs             TrustDoc[]
  trustInboxAttachments TrustInboxAttachment[]
}

model EvidenceChunk {
  id         String   @id @default(cuid())
  tenantId   String
  evidenceId String
  chunkIndex Int
  chunkText  String
  tokenCount Int
  embedding  Json
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  evidence   Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  @@unique([evidenceId, chunkIndex])
  @@index([tenantId, evidenceId])
}

model EvidenceLink {
  id         String    @id @default(cuid())
  tenantId   String
  evidenceId String
  questionId String?
  responseId String?
  createdAt  DateTime  @default(now())
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  evidence   Evidence  @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  question   Question? @relation(fields: [questionId], references: [id], onDelete: Cascade)
  response   Response? @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@index([tenantId, questionId])
  @@index([tenantId, responseId])
}

model AISuggestion {
  id           String   @id @default(cuid())
  tenantId     String
  assessmentId String?
  questionId   String?
  type         String
  prompt       String
  output       Json
  citations    String[]
  createdBy    String
  createdAt    DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Exception {
  id           String          @id @default(cuid())
  tenantId     String
  assessmentId String
  controlCode  String
  reason       String
  status       ExceptionStatus @default(OPEN)
  owner        String?
  approver     String?
  dueDate      DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessment   Assessment      @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([tenantId, assessmentId, status])
  @@index([tenantId, dueDate])
}

model Task {
  id                    String               @id @default(cuid())
  tenantId              String
  assessmentId          String?
  questionnaireUploadId String?
  questionnaireItemId   String?
  trustInboxItemId      String?
  aiUseCaseId           String?
  aiVendorReviewId      String?
  incidentId            String?
  incidentRunbookPackId String?
  tabletopExerciseId    String?
  title                 String
  controlCode           String?
  description           String?
  assignee              String?
  dueDate               DateTime?
  status                TaskStatus           @default(TODO)
  priority              TaskPriority         @default(MEDIUM)
  responseOpsPhase      ResponseOpsPhase?
  responseOpsOrder      Int?
  createdBy             String
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  tenant                Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessment            Assessment?          @relation(fields: [assessmentId], references: [id], onDelete: SetNull)
  questionnaireUpload   QuestionnaireUpload? @relation(fields: [questionnaireUploadId], references: [id], onDelete: SetNull)
  questionnaireItem     QuestionnaireItem?   @relation(fields: [questionnaireItemId], references: [id], onDelete: SetNull)
  trustInboxItem        TrustInboxItem?      @relation(fields: [trustInboxItemId], references: [id], onDelete: SetNull)
  aiUseCase             AIUseCase?           @relation(fields: [aiUseCaseId], references: [id], onDelete: SetNull)
  aiVendorReview        AIVendorReview?      @relation(fields: [aiVendorReviewId], references: [id], onDelete: SetNull)
  incident              Incident?            @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  incidentRunbookPack   IncidentRunbookPack? @relation(fields: [incidentRunbookPackId], references: [id], onDelete: SetNull)
  tabletopExercise      TabletopExercise?    @relation(fields: [tabletopExerciseId], references: [id], onDelete: SetNull)
  findings              Finding[]

  @@index([tenantId, status])
  @@index([tenantId, assessmentId])
  @@index([tenantId, questionnaireUploadId])
  @@index([tenantId, questionnaireItemId])
  @@index([tenantId, trustInboxItemId])
  @@index([tenantId, aiUseCaseId])
  @@index([tenantId, aiVendorReviewId])
  @@index([tenantId, incidentId])
  @@index([tenantId, incidentRunbookPackId])
  @@index([tenantId, tabletopExerciseId])
  @@index([tenantId, dueDate])
}

model EvidenceRequest {
  id           String                @id @default(cuid())
  tenantId     String
  assessmentId String?
  title        String
  details      String?
  assignee     String?
  status       EvidenceRequestStatus @default(REQUESTED)
  dueDate      DateTime?
  createdBy    String
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessment   Assessment?           @relation(fields: [assessmentId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, assessmentId])
}

model QuestionnaireImport {
  id            String                    @id @default(cuid())
  tenantId      String
  assessmentId  String
  sourceType    QuestionnaireSourceType
  status        QuestionnaireImportStatus @default(PENDING)
  rawPayload    Json
  createdBy     String
  createdAt     DateTime                  @default(now())
  appliedAt     DateTime?
  failureReason String?
  tenant        Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessment    Assessment                @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  rows          QuestionnaireImportRow[]

  @@index([tenantId, assessmentId])
}

model QuestionnaireImportRow {
  id                  String              @id @default(cuid())
  tenantId            String
  importId            String
  sourceQuestion      String
  sourceAnswer        String?
  sourceScore         Float?
  sourceConfidence    Float?
  mappedQuestionId    String?
  matchScore          Float?
  responseId          String?
  createdAt           DateTime            @default(now())
  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  questionnaireImport QuestionnaireImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  mappedQuestion      Question?           @relation(fields: [mappedQuestionId], references: [id], onDelete: SetNull)
  response            Response?           @relation(fields: [responseId], references: [id], onDelete: SetNull)

  @@index([tenantId, importId])
}

model QuestionnaireUpload {
  id                     String                      @id @default(cuid())
  tenantId               String
  organizationName       String?
  filename               String
  originalFormat         QuestionnaireOriginalFormat
  status                 QuestionnaireUploadStatus   @default(UPLOADED)
  parsedJson             Json
  createdBy              String
  assignedReviewerUserId String?
  reviewerUserId         String?
  reviewDueAt            DateTime?
  reviewedAt             DateTime?
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  tenant                 Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items                  QuestionnaireItem[]
  tasks                  Task[]
  trustPackets           TrustPacket[]
  evidenceMap            EvidenceMap?
  sourceApprovedAnswers  ApprovedAnswer[]
  findings               Finding[]
  trustInboxItem         TrustInboxItem?             @relation("TrustInboxUpload")
  trustRooms             TrustRoom[]
  trustRoomAccessRequests TrustRoomAccessRequest[]
  incidents              Incident[]

  @@index([tenantId, status, updatedAt])
  @@index([tenantId, assignedReviewerUserId, reviewDueAt])
  @@index([tenantId, createdAt])
}

model QuestionnaireItem {
  id                    String                 @id @default(cuid())
  tenantId              String
  questionnaireUploadId String
  rowKey                String
  rowOrder              Int
  questionText          String
  normalizedQuestion    String?
  contextJson           Json?
