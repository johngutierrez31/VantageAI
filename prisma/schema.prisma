generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantRole {
  ADMIN
  ANALYST
  VIEWER
  CLIENT_VIEWER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum TemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AssessmentStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
}

enum PlanTier {
  STARTER
  PRO
  PARTNER
}

enum StorageProvider {
  LOCAL
  S3
}

enum VectorProvider {
  HASHED
  OPENAI
}

enum EmailProvider {
  RESEND
}

enum IngestionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum QuestionnaireImportStatus {
  PENDING
  APPLIED
  FAILED
}

enum QuestionnaireSourceType {
  CSV
  JSON
}

enum ReportFormat {
  HTML
  MARKDOWN
  JSON
  PDF
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ExceptionStatus {
  OPEN
  ACCEPTED
  CLOSED
}

enum EvidenceRequestStatus {
  REQUESTED
  RECEIVED
  COMPLETE
}

model Tenant {
  id                    String                  @id @default(cuid())
  name                  String
  slug                  String                  @unique
  activeStorageProvider StorageProvider         @default(LOCAL)
  activeVectorProvider  VectorProvider          @default(HASHED)
  activeEmailProvider   EmailProvider           @default(RESEND)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  memberships           Membership[]
  templates             Template[]
  templateVersions      TemplateVersion[]
  controls              Control[]
  questions             Question[]
  assessments           Assessment[]
  responses             Response[]
  evidenceItems         Evidence[]
  evidenceChunks        EvidenceChunk[]
  evidenceLinks         EvidenceLink[]
  aiSuggestions         AISuggestion[]
  exceptions            Exception[]
  questionnaireImports  QuestionnaireImport[]
  questionnaireRows     QuestionnaireImportRow[]
  reports               Report[]
  reportExports         ReportExport[]
  tasks                 Task[]
  evidenceRequests      EvidenceRequest[]
  branding              TenantBranding?
  auditLogs             AuditLog[]
  stripeCustomers       StripeCustomer[]
  subscriptions         Subscription[]
  billingWebhookEvents  BillingWebhookEvent[]
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  memberships   Membership[]
  accounts      Account[]
  sessions      Session[]
}

model Membership {
  id        String           @id @default(cuid())
  tenantId  String
  userId    String
  role      TenantRole
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId, status])
}

model Template {
  id               String          @id @default(cuid())
  tenantId         String
  name             String
  description      String?
  status           TemplateStatus  @default(DRAFT)
  currentVersionId String?
  createdBy        String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  versions         TemplateVersion[]
  assessments      Assessment[]

  @@unique([tenantId, name])
}

model TemplateVersion {
  id          String       @id @default(cuid())
  tenantId    String
  templateId  String
  version     Int
  title       String
  notes       String?
  isPublished Boolean      @default(false)
  createdAt   DateTime     @default(now())
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template    Template     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  controls    Control[]

  @@unique([templateId, version])
  @@index([tenantId, templateId])
}

model Control {
  id                String          @id @default(cuid())
  tenantId          String
  templateVersionId String
  domain            String
  code              String
  title             String
  description       String?
  weight            Float           @default(1)
  createdAt         DateTime        @default(now())
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  templateVersion   TemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Cascade)
  questions         Question[]

  @@unique([templateVersionId, code])
  @@index([tenantId, templateVersionId])
}

model Question {
  id            String                   @id @default(cuid())
  tenantId      String
  controlId     String
  prompt        String
  rubric        String
  weight        Float                    @default(1)
  createdAt     DateTime                 @default(now())
  tenant        Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  control       Control                  @relation(fields: [controlId], references: [id], onDelete: Cascade)
  responses     Response[]
  evidenceLinks EvidenceLink[]
  importRows    QuestionnaireImportRow[]
}

model Assessment {
  id                 String                  @id @default(cuid())
  tenantId           String
  templateId         String
  templateVersionId  String
  name               String
  customerName       String
  status             AssessmentStatus        @default(DRAFT)
  createdBy          String
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  tenant             Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template           Template                @relation(fields: [templateId], references: [id], onDelete: Restrict)
  responses          Response[]
  questionnaireImports QuestionnaireImport[]
  reports            Report[]
  tasks              Task[]
  exceptions         Exception[]
  evidenceRequests   EvidenceRequest[]
}

model Response {
  id            String                   @id @default(cuid())
  tenantId      String
  assessmentId  String
  questionId    String
  answer        String?
  score         Float?
  confidence    Float?
  rationale     String?
  updatedBy     String
  updatedAt     DateTime                 @updatedAt
  createdAt     DateTime                 @default(now())
  tenant        Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessment    Assessment               @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question      Question                 @relation(fields: [questionId], references: [id], onDelete: Cascade)
  evidenceLinks EvidenceLink[]
  importRows    QuestionnaireImportRow[]

  @@unique([assessmentId, questionId])
  @@index([tenantId, assessmentId])
}

model Evidence {
  id             String          @id @default(cuid())
  tenantId       String
  name           String
  storageKey     String
  mimeType       String
  byteSize       Int?
  sha256         String?
  sourceUri      String?
  tags           String[]
  extractedText  String?
  ingestionStatus IngestionStatus @default(PENDING)
  ingestionError String?
  extractedAt    DateTime?
  createdBy      String
  createdAt      DateTime        @default(now())
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  links          EvidenceLink[]
  chunks         EvidenceChunk[]
}

model EvidenceChunk {
  id         String   @id @default(cuid())
  tenantId   String
  evidenceId String
  chunkIndex Int
  chunkText  String
  tokenCount Int
  embedding  Json
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  evidence   Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  @@unique([evidenceId, chunkIndex])
  @@index([tenantId, evidenceId])
}

model EvidenceLink {
  id         String    @id @default(cuid())
  tenantId   String
  evidenceId String
  questionId String?
  responseId String?
  createdAt  DateTime  @default(now())
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  evidence   Evidence  @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  question   Question? @relation(fields: [questionId], references: [id], onDelete: Cascade)
  response   Response? @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@index([tenantId, questionId])
  @@index([tenantId, responseId])
}

model AISuggestion {
  id           String   @id @default(cuid())
  tenantId     String
  assessmentId String?
  questionId   String?
  type         String
  prompt       String
  output       Json
  citations    String[]
  createdBy    String
  createdAt    DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Exception {
  id           String   @id @default(cuid())
  tenantId     String
  assessmentId String
  controlCode  String
  reason       String
  status       ExceptionStatus @default(OPEN)
  owner        String?
  approver     String?
  dueDate      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([tenantId, assessmentId, status])
  @@index([tenantId, dueDate])
}

model Task {
  id           String       @id @default(cuid())
  tenantId     String
  assessmentId String?
  title        String
  controlCode  String?
  description  String?
  assignee     String?
  dueDate      DateTime?
  status       TaskStatus   @default(TODO)
  priority     TaskPriority @default(MEDIUM)
  createdBy    String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessment   Assessment?  @relation(fields: [assessmentId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, assessmentId])
  @@index([tenantId, dueDate])
}

model EvidenceRequest {
  id           String                @id @default(cuid())
  tenantId     String
  assessmentId String?
  title        String
  details      String?
  assignee     String?
  status       EvidenceRequestStatus @default(REQUESTED)
  dueDate      DateTime?
  createdBy    String
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessment   Assessment?           @relation(fields: [assessmentId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, assessmentId])
}

model QuestionnaireImport {
  id           String                    @id @default(cuid())
  tenantId     String
  assessmentId String
  sourceType   QuestionnaireSourceType
  status       QuestionnaireImportStatus @default(PENDING)
  rawPayload   Json
  createdBy    String
  createdAt    DateTime                  @default(now())
  appliedAt    DateTime?
  failureReason String?
  tenant       Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessment   Assessment                @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  rows         QuestionnaireImportRow[]

  @@index([tenantId, assessmentId])
}

model QuestionnaireImportRow {
  id              String               @id @default(cuid())
  tenantId        String
  importId        String
  sourceQuestion  String
  sourceAnswer    String?
  sourceScore     Float?
  sourceConfidence Float?
  mappedQuestionId String?
  matchScore      Float?
  responseId      String?
  createdAt       DateTime             @default(now())
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  questionnaireImport QuestionnaireImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  mappedQuestion  Question?            @relation(fields: [mappedQuestionId], references: [id], onDelete: SetNull)
  response        Response?            @relation(fields: [responseId], references: [id], onDelete: SetNull)

  @@index([tenantId, importId])
}

model Report {
  id           String       @id @default(cuid())
  tenantId     String
  assessmentId String
  title        String
  summary      String
  markdown     String
  jsonPayload  Json
  generatedBy  String
  createdAt    DateTime     @default(now())
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessment   Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  exports      ReportExport[]

  @@index([tenantId, assessmentId])
}

model ReportExport {
  id         String       @id @default(cuid())
  tenantId   String
  reportId   String
  format     ReportFormat
  storageKey String?
  fileName   String
  createdBy  String
  createdAt  DateTime     @default(now())
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  report     Report       @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([tenantId, reportId])
}

model TenantBranding {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  companyName  String
  logoUrl      String?
  primaryColor String   @default("#0f172a")
  accentColor  String   @default("#2563eb")
  footerNote   String   @default("Not legal advice.")
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  actorUserId String
  entityType  String
  entityId    String
  action      String
  metadata    Json
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

model StripeCustomer {
  id               String   @id @default(cuid())
  tenantId         String
  stripeCustomerId String   @unique
  createdAt        DateTime @default(now())
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId])
}

model Subscription {
  id                   String   @id @default(cuid())
  tenantId             String
  plan                 PlanTier @default(STARTER)
  stripeSubscriptionId String?  @unique
  status               String
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean  @default(false)
  endedAt              DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

model BillingWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  tenantId      String?
  type          String
  payload       Json
  processedAt   DateTime @default(now())
  tenant        Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
